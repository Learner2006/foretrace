# ForeTrace Backend Environment Configuration Example
# Copy this file to .env and fill in your values

# Your Groq API Key (Required)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxx"

# Environment Stage (Optional, options: 'dev' or 'prod', default: 'dev')
ENV="dev"

# Authentication Token / API Key (Optional in dev, required in prod)
API_KEY="demo_token"

# Optional: Set the frontend URL for CORS in production
FRONTEND_URL="http://127.0.0.1:5173"

# Optional: Redis connection string for distributed rate limiting (default: in-memory)
REDIS_URL="redis://localhost:6379/0"

# Optional: Disable demo data mode (boolean, default: False)
DISABLE_DEMO_DATA=False
